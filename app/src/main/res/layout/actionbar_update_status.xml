<?xml version="1.0" encoding="utf-8"?>
<!-- Action-bar contents: app name on the left, then a stacked pair on the right
     for "Installed: vX.Y.Z" (always current from BuildConfig.VERSION_NAME) and
     "Latest Release: vA.B.C · <phase>" (driven by Updater). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingEnd="8dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="12dp"
        android:orientation="vertical">
        <TextView
            android:id="@+id/tvInstalled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:textSize="11sp"
            android:textColor="#FFFFFF" />
        <TextView
            android:id="@+id/tvLatest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:textSize="11sp"
            android:textColor="#FFFFFF" />
    </LinearLayout>
</LinearLayout>
