<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:layout_marginBottom="2dp" />

        <TextView
            android:id="@+id/tvVersion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/text_subtle"
            android:layout_marginBottom="16dp" />

        <!-- Credentials -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/credentials"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilUserToken"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/user_token_hint"
                    android:layout_marginBottom="8dp"
                    app:helperText="@string/user_token_helper">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etUserToken"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:singleLine="true" />
                </com.google.android.material.textfield.TextInputLayout>

<com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilCarModel"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/car_model_hint"
                    android:layout_marginBottom="12dp">
                    <AutoCompleteTextView
                        android:id="@+id/actvCarModel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnValidate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/validate_and_save" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Live Vehicle Data -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/live_vehicle_data"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <!-- SOC row -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="@string/state_of_charge" android:textSize="14sp" />
                    <TextView android:id="@+id/tvSoc" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="--" android:textSize="14sp" android:textStyle="bold" />
                </LinearLayout>

                <!-- Speed row -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="@string/speed" android:textSize="14sp" />
                    <TextView android:id="@+id/tvSpeed" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="--" android:textSize="14sp" android:textStyle="bold" />
                </LinearLayout>

                <!-- Charging row -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="@string/charging_state" android:textSize="14sp" />
                    <TextView android:id="@+id/tvCharging" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="--" android:textSize="14sp" android:textStyle="bold" />
                </LinearLayout>

                <!-- Temp row -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="@string/outside_temp" android:textSize="14sp" />
                    <TextView android:id="@+id/tvTemp" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="--" android:textSize="14sp" android:textStyle="bold" />
                </LinearLayout>

                <!-- Odometer row -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="@string/odometer" android:textSize="14sp" />
                    <TextView android:id="@+id/tvOdometer" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="--" android:textSize="14sp" android:textStyle="bold" />
                </LinearLayout>

                <!-- Range row -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="@string/range" android:textSize="14sp" />
                    <TextView android:id="@+id/tvRange" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="--" android:textSize="14sp" android:textStyle="bold" />
                </LinearLayout>

                <!-- GPS row -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="@string/gps_location" android:textSize="14sp" />
                    <TextView android:id="@+id/tvGps" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="--" android:textSize="12sp" android:textStyle="bold" android:fontFamily="monospace" />
                </LinearLayout>

                <!-- Heading row -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="@string/heading" android:textSize="14sp" />
                    <TextView android:id="@+id/tvHeading" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="--" android:textSize="14sp" android:textStyle="bold" />
                </LinearLayout>

                <!-- Elevation row -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="@string/elevation" android:textSize="14sp" />
                    <TextView android:id="@+id/tvElevation" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="--" android:textSize="14sp" android:textStyle="bold" />
                </LinearLayout>

                <!-- Car API Connection -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="@string/car_api" android:textSize="13sp" android:textColor="@color/text_subtle" />
                    <TextView android:id="@+id/tvCarConnection" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Connecting…" android:textSize="13sp" android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Status & Control -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/status"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/not_started"
                    android:textSize="14sp"
                    android:layout_marginBottom="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStartStop"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/start_telemetry"
                    android:backgroundTint="@color/btn_start" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Log -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/activity_log"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnClearLog"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/clear" />
                </LinearLayout>

                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="220dp">
                    <TextView
                        android:id="@+id/tvLog"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:textSize="11sp"
                        android:textIsSelectable="true" />
                </ScrollView>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
